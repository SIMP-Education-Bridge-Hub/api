// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  userId  String  @id @default(uuid())
  roleId  String
  name    String
  surname String
  status  String
  email   String?
  phone   String?
}

model School {
  schoolId     String @id @default(uuid())
  principalId  String @unique
  name         String
  email        String
  phone        String
  address      String
  capacity     Int
  lowestGrade  Int
  highestGrade Int
}

model Classroom {
  classroomId String @id @default(uuid())
  teacherId   String @unique
  schoolId    String
  name        String
  capacity    Int
}

model Permission {
  permissionId String @id @default(uuid())
  action       String
  table        String
}

model Role {
  roleId String @id @default(uuid())
  title  String
}

model RolePermission {
  rolePermissionId String @id @default(uuid())
  roleId           String
  permissionId     String
}
